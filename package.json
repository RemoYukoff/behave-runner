{
    "name": "behave-runner",
    "displayName": "Behave Runner",
    "description": "Run Behave from CodeLens in .feature files and the Live run panel (run/debug), with Go to Definition, step autocomplete, and more.",
    "version": "1.14.10",
    "author": "Remo Yukoff <remo.yukoff@gmail.com>",
    "publisher": "remoyukoff",
    "repository": {
        "type": "git",
        "url": "https://github.com/RemoYukoff/behave-runner"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Testing",
        "Programming Languages"
    ],
    "keywords": [
        "behave",
        "bdd",
        "gherkin",
        "cucumber",
        "feature",
        "python",
        "test"
    ],
    "activationEvents": [
        "workspaceContains:**/*.feature"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "behave",
                "aliases": [
                    "Behave",
                    "feature"
                ],
                "extensions": [
                    ".feature"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "behaveComment",
                "superType": "comment",
                "description": "Line comments and language pragma in .feature files"
            },
            {
                "id": "behaveStructuralKeyword",
                "superType": "keyword",
                "description": "Feature:, Scenario:, Background:, Examples:, Rule:, …"
            },
            {
                "id": "behaveStepKeyword",
                "superType": "keyword",
                "description": "Given, When, Then, And, But, *"
            },
            {
                "id": "behaveTitle",
                "superType": "class",
                "description": "Titles after structural keywords"
            },
            {
                "id": "behaveStepText",
                "superType": "string",
                "description": "Step body text"
            },
            {
                "id": "behaveDocstring",
                "superType": "string",
                "description": "Triple-quoted / fenced docstrings"
            },
            {
                "id": "behaveTable",
                "superType": "string",
                "description": "Example / data table rows"
            },
            {
                "id": "behavePlaceholder",
                "superType": "variable",
                "description": "Outline placeholders <name>"
            },
            {
                "id": "behaveTag",
                "superType": "namespace",
                "description": "Tags (@tag)"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "behave",
                "scopes": {
                    "behaveComment": [
                        "comment.line.number-sign",
                        "comment.line"
                    ],
                    "behaveStructuralKeyword": [
                        "keyword.control",
                        "keyword.other"
                    ],
                    "behaveStepKeyword": [
                        "entity.name.function",
                        "keyword.other"
                    ],
                    "behaveTitle": [
                        "entity.name.type.class",
                        "entity.name"
                    ],
                    "behaveStepText": [
                        "string.unquoted",
                        "markup.inserted"
                    ],
                    "behaveDocstring": [
                        "string.quoted.docstring",
                        "string.quoted"
                    ],
                    "behaveTable": [
                        "string.other",
                        "markup.inline.raw"
                    ],
                    "behavePlaceholder": [
                        "constant.character.format.placeholder",
                        "variable.other"
                    ],
                    "behaveTag": [
                        "entity.name.tag",
                        "support.variable.annotation"
                    ]
                }
            }
        ],
        "configurationDefaults": {
            "editor.semanticTokenColorCustomizations": {
                "rules": {
                    "behaveTag:behave": "#FFA500",
                    "behavePlaceholder:behave": "#FF8DC7"
                },
                "[*Dark*]": {
                    "rules": {
                        "behaveStepText:behave": "#FFFFFF"
                    }
                },
                "[*Light*]": {
                    "rules": {
                        "behaveStepText:behave": "#1a1a1a"
                    }
                }
            }
        },
        "viewsContainers": {
            "panel": [
                {
                    "id": "behaveRunnerExecutionPanel",
                    "title": "Behave",
                    "icon": "media/behave-activity.svg"
                }
            ]
        },
        "views": {
            "behaveRunnerExecutionPanel": [
                {
                    "type": "webview",
                    "id": "behaveRunner.liveRun",
                    "name": "Live run",
                    "visibility": "visible"
                }
            ]
        },
        "configuration": {
            "title": "Behave Runner",
            "properties": {
                "behaveRunner.debug.justMyCode": {
                    "type": "boolean",
                    "default": true,
                    "description": "Only debug user code when running Behave in debug mode."
                },
                "behaveRunner.stepDefinitions.patterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/steps/**/*.py",
                        "**/*_steps.py",
                        "**/step_*.py",
                        "**/steps.py"
                    ],
                    "description": "Glob patterns for Python files containing step definitions."
                },
                "behaveRunner.featureFiles.patterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/*.feature"
                    ],
                    "description": "Glob patterns for Gherkin feature files."
                }
            }
        }
    },
    "scripts": {
        "build:webview": "esbuild src/webview/liveRunPanelScript.ts --bundle --platform=browser --target=es2020 --outfile=media/liveRunPanel.bundle.js",
        "compile": "npm run build:webview && tsc -p packages/behave-runner-core/tsconfig.json && tsc -p packages/behave-runner-lsp/tsconfig.json && tsc -p ./ && tsc -p src/webview/tsconfig.json",
        "watch": "tsc -watch -p ./",
        "copy-codicons": "node -e \"const fs=require('fs'),p=require('path');const r=p.join('node_modules','@vscode','codicons','dist');const d=p.join('media','codicons');if(!fs.existsSync(p.join(r,'codicon.css'))){console.warn('Behave Runner: @vscode/codicons not installed; skip copy-codicons');process.exit(0);}fs.mkdirSync(d,{recursive:true});['codicon.css','codicon.ttf'].forEach(f=>fs.copyFileSync(p.join(r,f),p.join(d,f)));\"",
        "prepare": "npm run copy-codicons",
        "vscode:prepublish": "npm run compile && npm run copy-codicons",
        "test": "npm run compile"
    },
    "dependencies": {
        "@behave-runner/core": "workspace:*",
        "@behave-runner/lsp": "workspace:*",
        "@vscode/codicons": "^0.0.45",
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.0.0"
    },
    "license": "MIT",
    "workspaces": [
        "packages/behave-runner-core",
        "packages/behave-runner-lsp"
    ]
}
